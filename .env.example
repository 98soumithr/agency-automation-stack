# =============================================================================
# Agency Automation Stack — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- General ---
TIMEZONE=America/New_York

# --- n8n ---
N8N_DB_PASSWORD=n8n_secret_change_me
N8N_ENCRYPTION_KEY=generate-a-random-64-char-string-here

# --- OpenOutreach (LinkedIn Automation) ---
LLM_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o
LLM_API_BASE=

# --- Postiz (Social Media Scheduler) ---
POSTIZ_DB_PASSWORD=postiz_secret_change_me
POSTIZ_JWT_SECRET=type-random-characters-here-make-it-long

# --- Social Media API Keys (fill as needed) ---
POSTIZ_LINKEDIN_CLIENT_ID=
POSTIZ_LINKEDIN_CLIENT_SECRET=
POSTIZ_X_API_KEY=
POSTIZ_X_API_SECRET=
POSTIZ_FACEBOOK_APP_ID=
POSTIZ_FACEBOOK_APP_SECRET=
POSTIZ_THREADS_APP_ID=
POSTIZ_THREADS_APP_SECRET=
POSTIZ_REDDIT_CLIENT_ID=
POSTIZ_REDDIT_CLIENT_SECRET=
POSTIZ_TIKTOK_CLIENT_ID=
POSTIZ_TIKTOK_CLIENT_SECRET=
POSTIZ_YOUTUBE_CLIENT_ID=
POSTIZ_YOUTUBE_CLIENT_SECRET=
POSTIZ_PINTEREST_CLIENT_ID=
POSTIZ_PINTEREST_CLIENT_SECRET=
POSTIZ_DISCORD_CLIENT_ID=
POSTIZ_DISCORD_CLIENT_SECRET=
POSTIZ_SLACK_ID=
POSTIZ_SLACK_SECRET=

# --- OpenAI (for Postiz AI copilot + n8n workflows) ---
OPENAI_API_KEY=sk-your-openai-key-here
